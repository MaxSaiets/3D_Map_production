# =============================================================
# .env.production.example
# Скопіюй як /opt/3dmap/frontend/.env.production та заповни
# =============================================================

# URL до backend API.
# Для продакшну краще НЕ задавати: frontend ходить у same-origin /api,
# а nginx проксіює /api/ -> 127.0.0.1:8000.
# NEXT_PUBLIC_API_URL=

# Для локальної розробки Next.js rewrite проксіює /api на backend:
# NEXT_LOCAL_API_URL=http://127.0.0.1:8000
