# =============================================================
# .env.production.example
# Скопіюй як /opt/3dmap/frontend/.env.production та заповни
# =============================================================

# URL до backend API без /api в кінці.
# Якщо nginx проксіює /api/ на backend, залиш порожнім або вкажи origin:
NEXT_PUBLIC_API_URL=http://209.38.210.197
# Або з доменом:
# NEXT_PUBLIC_API_URL=https://yourdomain.com

# Firebase Web App config (Project settings -> General -> Your apps -> Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
