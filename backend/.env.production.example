# =============================================================
# .env.production.example
# Скопіюй як /opt/3dmap/backend/.env та заповни значення
# =============================================================

# ── Сервер ────────────────────────────────────────────────────
# Дозволені origins для CORS (фронтенд)
# Якщо є домен — вказати його, інакше IP
ALLOWED_ORIGINS=http://209.38.210.197,https://yourdomain.com

# ── Файли ─────────────────────────────────────────────────────
# Тимчасова директорія для згенерованих моделей
# Файли видаляються автоматично після upload у Firebase
OUTPUT_DIR=/tmp/3dmap_output
KEEP_LOCAL_FILES=false

# ── Firebase Storage ──────────────────────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Варіант 1: JSON credentials у env змінній (рекомендовано для продакшну)
# Вміст serviceAccountKey.json в одному рядку:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Варіант 2: Шлях до файлу ключа (якщо файл є на сервері поза репо)
# FIREBASE_CREDENTIALS_PATH=/opt/3dmap/secrets/serviceAccountKey.json

# ── Акаунти / ліміти ─────────────────────────────────────────
# Firebase Auth використовує той самий service account JSON.
# У Firebase Console увімкни Authentication -> Sign-in method -> Google.
USER_DATA_DIR=/opt/3dmap/backend/output/user_data
FREE_FULL_GENERATION_LIMIT=10

# ── Elevation / DEM ───────────────────────────────────────────
ELEVATION_PROVIDER=terrarium
TERRARIUM_URL=https://s3.amazonaws.com/elevation-tiles-prod/terrarium
TERRARIUM_ZOOM=14
TERRARIUM_CACHE_DIR=/opt/3dmap/backend/cache/terrarium
TERRARIUM_TIMEOUT=30

# ── OSM ───────────────────────────────────────────────────────
# За замовчуванням — live Overpass API (добре для невеликих зон)
# Для великих зон України розкоментуй PBF:
# OSM_SOURCE=pbf
# OSM_PBF_PATH=/opt/3dmap/backend/cache/osm/ukraine-latest.osm.pbf
# OSM_PBF_AUTO_DOWNLOAD=1

# ── Debug ─────────────────────────────────────────────────────
ELEVATION_DEBUG=0
